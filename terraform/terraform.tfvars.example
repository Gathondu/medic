# Copy to terraform.tfvars (gitignored) and fill in secrets.
# Or export TF_VAR_* and pass -var-file for non-secret values only.

aws_region = "us-east-1"

# If the App Runner ECR access role already exists in IAM, skip creating it and look it up by name:
# create_apprunner_ecr_access_role = false
# apprunner_ecr_access_role_name    = "consultation-app-apprunner-ecr-access" # optional; default matches project_name

# Optional overrides (defaults match the course names)
# project_name              = "consultation-app"
# ecr_repository_name       = "consultation-app"
# app_runner_service_name   = "consultation-app-service"
# app_runner_cpu            = "256"
# app_runner_memory         = "512"
# openrouter_base_url       = "https://openrouter.ai/api/v1"

# Required secrets (do not commit real values)
# clerk_jwks_url      = "https://your-instance.clerk.accounts.dev/.well-known/jwks.json"
# openrouter_api_key  = "sk-or-v1-..."
